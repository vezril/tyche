# Copy to .env before `docker compose up -d`, then set MASTER_KEY (see README
# "First-run setup" — one sed/openssl line).

# Host port the app is published on (LAN only — never port-forward this).
PORT=8080

# Container timezone (affects displayed dates/logs).
TZ=America/Toronto

# Data-encryption master key (AES-256-GCM, ADR-007). REQUIRED — the app
# refuses to start without it. Generate: openssl rand -hex 32
# Never stored in the database or in backups — BACK THIS FILE UP SEPARATELY.
# Losing it keeps all budget data but forces re-entering the Plaid secret and
# re-linking bank connections (see README "MASTER_KEY management").
MASTER_KEY=

# Plaid credentials (E5) — may also be set via the Settings UI.
#PLAID_CLIENT_ID=
#PLAID_SECRET=
