{
  "name": "@ynab-clone/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fastify app server: domain modules (budget/ledger/importing/auth/admin/web per ADR-001), SQLite + migrations (ADR-003).",
  "main": "./dist/index.js",
  "bin": {
    "ynab-clone": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "cli": "tsx src/cli.ts",
    "sync:sandbox": "tsx src/plaid-sandbox-sync.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@ynab-clone/shared": "*",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.0.0",
    "fastify": "^5.0.0",
    "plaid": "^42.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
